# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is gitignored and will NOT be committed.

wifi_ssid: "your_wifi_ssid"
wifi_password: "your_wifi_password"

# Generate a new API key: esphome wizard (or any base64 32-byte key)
api_encryption_key: "REPLACE_WITH_YOUR_BASE64_KEY"

# Generate: openssl rand -hex 16
ota_password: "REPLACE_WITH_YOUR_OTA_PASSWORD"

# Fallback AP password (used when WiFi is unavailable)
fallback_ap_password: "REPLACE_WITH_FALLBACK_PASSWORD"
